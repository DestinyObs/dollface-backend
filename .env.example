# Copy to .env and fill in
PORT=4200
NODE_ENV=development
PUBLIC_URL=http://localhost:4200

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://dollface:dollface@localhost:5434/dollface?schema=public

# Auth — use long random strings in production
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS (comma-separated). Mobile web preview + web landing.
CORS_ORIGINS=http://localhost:19006,http://localhost:4100

# Comma-separated emails that become ADMIN on sign-in.
ADMIN_EMAILS=

# ─────────────────────────────────────────────────────────────
# External providers — SDKs are wired in src/providers/*. Each goes REAL the
# moment its key is set; without a key it falls back to dev behaviour so every
# flow stays testable.
# ─────────────────────────────────────────────────────────────
# Payments (Stripe) — real PaymentIntents/SetupIntents when set
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# In-app purchases (RevenueCat)
# REVENUECAT_WEBHOOK_SECRET=
# Email — Resend (preferred) OR SMTP; real send when set
# RESEND_API_KEY=
# SMTP_URL=smtp://user:pass@host:587
# EMAIL_FROM=DollFace <no-reply@dollface.app>
# Push notifications (Expo) — real Expo push for valid device tokens
# EXPO_ACCESS_TOKEN=
# Media storage — Cloudinary (preferred) OR S3; uploads go to cloud when set
# CLOUDINARY_URL=cloudinary://key:secret@cloud
# AWS_S3_BUCKET=
# AWS_REGION=eu-west-2
# Social login — real Google ID-token verification when set
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=
# ─────────────────────────────────────────────────────────────
# AI vision — real shade matching + look recreation (Anthropic Claude).
# Provide ONE OR MORE keys, comma-separated. They are tried in order on
# failure (rate-limit / quota / bad key), so add 2-3 for resilience.
# Without any key, scanning still works but returns a sample analysis.
# ─────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2,sk-ant-key3
# Cheap, vision-capable default; override only if needed:
# ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001
