# Copy to .env and fill in
PORT=4200
NODE_ENV=development

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://dollface:dollface@localhost:5434/dollface?schema=public

# Auth — use long random strings in production
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS (comma-separated). Mobile web preview + web landing.
CORS_ORIGINS=http://localhost:19006,http://localhost:4100
